FROM oven/bun:1.2.19-alpine AS ui-builder
ARG BLEEPHUB_VERSION=development
ARG BLEEPHUB_PUBLISHED_AT=not-yet-published
ENV VITE_BLEEPHUB_VERSION=$BLEEPHUB_VERSION \
    VITE_BLEEPHUB_PUBLISHED_AT=$BLEEPHUB_PUBLISHED_AT
WORKDIR /src/web
COPY web/package.json web/bun.lock web/tsconfig.base.json ./
COPY web/core ./core
COPY web/src ./src
COPY web/public ./public
COPY web/index.html web/knip.ts web/tsconfig.json web/vite.config.ts ./
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile && bun run build

FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY . .
COPY --from=ui-builder /src/web/dist/ ./internal/server/dist/
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bleephub ./cmd/bleephub && \
    CGO_ENABLED=0 go build -ldflags="-s -w" -o /bleephub-ssh-gateway ./ssh-gateway

FROM golang:1.25-bookworm AS go-toolchain

FROM ubuntu:24.04 AS dqlite-builder
COPY --from=go-toolchain /usr/local/go /usr/local/go
ENV PATH=/usr/local/go/bin:$PATH
RUN apt_transaction() { rm -rf /var/lib/apt/lists/*; apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends "$@"; }; \
    retry_apt_transaction() { apt_transaction "$@" || apt_transaction "$@"; }; \
    retry_apt_transaction ca-certificates software-properties-common && \
    add-apt-repository -y ppa:dqlite/dev && \
    retry_apt_transaction build-essential libdqlite-dev && \
    rm -rf /var/lib/apt/lists/*
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY dqlite-node ./dqlite-node
COPY internal/dqliteaddr ./internal/dqliteaddr
RUN CGO_ENABLED=1 go build -tags 'nosqlite3,dqlite' -ldflags="-s -w" -o /bleephub-dqlite-node ./dqlite-node

FROM ubuntu:24.04
RUN apt_transaction() { rm -rf /var/lib/apt/lists/*; apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends "$@"; }; \
    retry_apt_transaction() { apt_transaction "$@" || apt_transaction "$@"; }; \
    retry_apt_transaction ca-certificates ruby-full ruby-bundler software-properties-common && \
    add-apt-repository -y ppa:dqlite/dev && \
    retry_apt_transaction build-essential git libdqlite0 && \
    mkdir -p /opt/bleephub-pages && \
    printf '%s\n' 'source "https://rubygems.org"' 'gem "github-pages", "= 232"' > /opt/bleephub-pages/Gemfile && \
    BUNDLE_GEMFILE=/opt/bleephub-pages/Gemfile bundle install && \
    apt-get purge -y --auto-remove build-essential software-properties-common && \
    rm -rf /var/lib/apt/lists/* /root/.bundle/cache /usr/local/bundle/cache
COPY --from=builder /bleephub /usr/local/bin/bleephub
COPY --from=builder /bleephub-ssh-gateway /usr/local/bin/bleephub-ssh-gateway
COPY --from=dqlite-builder /bleephub-dqlite-node /usr/local/bin/bleephub-dqlite-node
COPY pages-jekyll /usr/local/bin/bleephub-pages-jekyll
RUN chmod 0755 /usr/local/bin/bleephub-pages-jekyll
ENTRYPOINT ["bleephub"]
