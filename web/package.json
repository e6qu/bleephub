{
  "name": "@bleephub/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["core"],
  "scripts": {
    "dev": "vite",
    "build": "bun --bun vite build",
    "preview": "vite preview",
    "test": "vitest run",
